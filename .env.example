# GabaritoWEB — variáveis de ambiente (copie para .env na raiz do projeto)

# Caminho do banco SQLite
# DATABASE_PATH=./data/dev/gabarito.db

# Origem CORS permitida em produção (padrão: https://gabarito.sistema.pro.br)
# CORS_ORIGIN=https://gabarito.sistema.pro.br

# Ambiente Node (development | production)
# NODE_ENV=development

# URL do backend para proxy do Vite em desenvolvimento
# BACKEND_URL=http://localhost:3000

# --- Superadmin (somente leitura) ---
# Token secreto para a área /superadmin. Se não definido, os endpoints ficam desabilitados (404).
# Gere com: openssl rand -hex 32
# SUPERADMIN_TOKEN=

# Lista opcional de IPs permitidos (separados por vírgula)
# SUPERADMIN_ALLOWED_IPS=127.0.0.1,::1

# Retenção de logs de acesso em dias (padrão: 90)
# ACCESS_LOG_RETENTION_DAYS=90
